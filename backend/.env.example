APP_NAME=CrisisClassifier API
ENV=development
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=sqlite:///./data/app.db

# Model configuration
# Options:
# - keywords: fast heuristic baseline (no ML deps at runtime besides this repo)
# - zero_shot: NLI-based zero-shot multi-label classifier (heavier, but works without fine-tuning)
CLASSIFIER_BACKEND=zero_shot

# Hugging Face models
ZERO_SHOT_MODEL_ID=typeform/distilbert-base-uncased-mnli

# If you later fine-tune a crisis-specific checkpoint, set it here and switch backend accordingly.
HF_MODEL_ID=

# Request limits
MAX_TEXT_CHARS=20000

# Live feed (RSS)
RSS_FEEDS=https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://feeds.bbci.co.uk/news/world/rss.xml
LIVE_FEED_LIMIT=12
